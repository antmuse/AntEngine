{
    "Daemon": false,
    "Print": 1, //0=disable print, 1=main process print, 2=all process print
    "LogPath": "Log/",
    "PidFile": "Log/pid.txt",
    "ShareMem": "GMEM/MainMem.map", //共享内存名
    "ShareMemSize": 1, //[1-10 * 1024], 1MB
    "AcceptPost": 10, //[1-255]监听端口上侯命的请求数
    "ThreadPool": 3, //[1-255]
    "Process": 0, //进程数
    "TLS": {
        "Ciphers": "HIGH:!aNULL:!MD5", //for TLSv1.2
        "Ciphersuites": "", //for TLSv1.3
        "CA": "Config/eng_ca.crt",
        "Cert": "Config/eng.crt",
        "Key": "Config/eng.key",
        "VersionOff": "v1.0, v1.1",
        "VerifyDepth": 5,
        "HttpALPN": 1,
        "PreferServerCiphers": true,
        "Debug": false,
        "Verify": 0
    }
}
